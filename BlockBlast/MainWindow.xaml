<Window x:Class="BlockBlast.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BlockBlast!"
        Icon="Assets/icon.ico"
        Width="560" Height="860"
        MinWidth="480" MinHeight="760"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

    <Window.Resources>
        <LinearGradientBrush x:Key="AppBackgroundBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF6EC6FF" Offset="0"/>
            <GradientStop Color="#FF7C6CF0" Offset="0.55"/>
            <GradientStop Color="#FF9B5CE0" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RoundButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#FFFFFFFF"/>
            <Setter Property="Foreground" Value="#FF5A3FBE"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="18"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,20,20,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="TitleText"
                       Grid.Column="0"
                       Text="BlockBlast!"
                       FontSize="28" FontWeight="Black"
                       Foreground="White"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                <Border Background="#33FFFFFF" CornerRadius="14" Padding="16,6" Margin="4,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="ScoreLabel" Text="SCORE" FontSize="11" FontWeight="Bold"
                                   Foreground="#DDFFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="ScoreValueText" Text="0" FontSize="22" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#33FFFFFF" CornerRadius="14" Padding="16,6" Margin="4,0">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock x:Name="BestLabel" Text="BEST" FontSize="11" FontWeight="Bold"
                                   Foreground="#DDFFFFFF" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="BestValueText" Text="0" FontSize="22" FontWeight="Black"
                                   Foreground="White" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Button x:Name="LangButton"
                    Grid.Column="2"
                    Content="RU"
                    Style="{StaticResource RoundButtonStyle}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"
                    Click="LangButton_Click"/>
        </Grid>

        <Viewbox Grid.Row="1" Stretch="Uniform" Margin="16">
            <Border x:Name="BoardBorder"
                    Background="#22111133"
                    CornerRadius="18"
                    Padding="10">
                <Grid x:Name="BoardGrid" Width="416" Height="416"/>
            </Border>
        </Viewbox>

        <Border Grid.Row="2" Margin="16,0,16,20" Background="#22111133" CornerRadius="18" Padding="10,14">
            <StackPanel x:Name="TrayPanel" Orientation="Horizontal" HorizontalAlignment="Center"/>
        </Border>

        <Canvas x:Name="OverlayCanvas" Grid.Row="0" Grid.RowSpan="3" IsHitTestVisible="False"/>

        <Border x:Name="GameOverOverlay"
                Grid.Row="0" Grid.RowSpan="3"
                Background="#CC1B1030"
                Visibility="Collapsed">
            <Border Background="White"
                    CornerRadius="24"
                    Padding="36,30"
                    MaxWidth="360"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock x:Name="GameOverTitleText"
                               Text="Game Over"
                               FontSize="30" FontWeight="Black"
                               Foreground="#FF5A3FBE"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,18"/>
                    <TextBlock x:Name="GameOverScoreLabelText"
                               Text="Your score"
                               FontSize="14" FontWeight="Bold"
                               Foreground="#FF8A7FB0"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="GameOverScoreText"
                               Text="0"
                               FontSize="40" FontWeight="Black"
                               Foreground="#FFFF7A45"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,14"/>
                    <TextBlock x:Name="GameOverNewBestText"
                               Text="New record!"
                               FontSize="15" FontWeight="Bold"
                               Foreground="#FF2FB380"
                               HorizontalAlignment="Center"
                               Visibility="Collapsed"
                               Margin="0,0,0,10"/>
                    <TextBlock x:Name="GameOverBestLabelText"
                               Text="Best score"
                               FontSize="13"
                               Foreground="#FF8A7FB0"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="GameOverBestText"
                               Text="0"
                               FontSize="20" FontWeight="Bold"
                               Foreground="#FF5A3FBE"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,22"/>
                    <Button x:Name="RestartButton"
                            Content="Start again"
                            Style="{StaticResource RoundButtonStyle}"
                            Background="#FF5A3FBE"
                            Foreground="White"
                            FontSize="16"
                            Padding="26,12"
                            Click="RestartButton_Click"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
